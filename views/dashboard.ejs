<% const { kpi, timeline, topCustomers, mapData, aging, priorityChart } = pageData; %>

<div class="grid">
    <div class="glass-card col-3">
        <div class="kpi-label">Receita Total</div>
        <div class="kpi-val"><%= formatMoney(kpi.total) %></div>
        <div class="kpi-trend"><%= kpi.count %> notas emitidas</div>
    </div>
    <div class="glass-card col-3">
        <div class="kpi-label">A Receber (Pendente)</div>
        <div class="kpi-val" style="color: var(--danger);"><%= formatMoney(kpi.pending) %></div>
        <div class="kpi-trend trend-down">Falta receber</div>
    </div>
    <div class="glass-card col-3">
        <div class="kpi-label">Em Caixa (Pago)</div>
        <div class="kpi-val" style="color: var(--success);"><%= formatMoney(kpi.paid) %></div>
        <div class="kpi-trend trend-up">Confirmado</div>
    </div>
    <div class="glass-card col-3">
        <div class="kpi-label">Ticket Médio</div>
        <div class="kpi-val"><%= formatMoney(kpi.ticket) %></div>
    </div>
</div>

<!-- Aging KPIs -->
<div class="grid">
    <div class="glass-card col-4 kpi-bordered border-critico">
        <div class="kpi-label" style="color: var(--danger);">
            <i class="fa-solid fa-triangle-exclamation"></i> Atraso Crítico (> 30 dias)
        </div>
        <div class="kpi-val" style="color: var(--danger);"><%= formatMoney(aging.critico_val || 0) %></div>
        <div class="kpi-trend trend-down"><%= aging.critico_count || 0 %> notas vencidas</div>
    </div>
    <div class="glass-card col-4 kpi-bordered border-alerta">
        <div class="kpi-label" style="color: #b38f00;">
            <i class="fa-solid fa-clock"></i> Atraso Leve (1 a 30 dias)
        </div>
        <div class="kpi-val" style="color: #b38f00;"><%= formatMoney(aging.alerta_val || 0) %></div>
        <div class="kpi-trend"><%= aging.alerta_count || 0 %> notas em alerta</div>
    </div>
    <div class="glass-card col-4 kpi-bordered border-noprazo">
        <div class="kpi-label" style="color: var(--success);">
            <i class="fa-solid fa-check-circle"></i> No Prazo / A Vencer
        </div>
        <div class="kpi-val" style="color: var(--success);"><%= formatMoney(aging.noprazo_val || 0) %></div>
        <div class="kpi-trend trend-up"><%= aging.noprazo_count || 0 %> notas no prazo</div>
    </div>
</div>

<!-- Priority Chart + Top Customers -->
<div class="grid">
    <div class="glass-card col-8">
        <div class="kpi-label">
            <i class="fa-solid fa-ranking-star"></i> Prioridade de Cobrança por Cliente (Pendentes)
        </div>
        <div style="display: flex; gap: 16px; margin: 10px 0 0;">
            <span style="font-size: 0.8rem; font-weight: 600; display: flex; align-items: center; gap: 4px;">
                <span style="width:10px;height:10px;background:#ff3b30;border-radius:2px;display:inline-block;"></span> Crítico
            </span>
            <span style="font-size: 0.8rem; font-weight: 600; display: flex; align-items: center; gap: 4px;">
                <span style="width:10px;height:10px;background:#ffcc00;border-radius:2px;display:inline-block;"></span> Alerta
            </span>
            <span style="font-size: 0.8rem; font-weight: 600; display: flex; align-items: center; gap: 4px;">
                <span style="width:10px;height:10px;background:#34c759;border-radius:2px;display:inline-block;"></span> No Prazo
            </span>
        </div>
        <div class="chart-scroll" style="height: 420px; margin-top: 10px;">
            <div style="height: <%= Math.max(300, (priorityChart || []).length * 38) %>px; position: relative;">
                <canvas id="chartPriority"></canvas>
            </div>
        </div>
    </div>
    <div class="glass-card col-4">
        <div class="kpi-label">Top 5 Clientes</div>
        <canvas id="chartTopCustomers" height="200"></canvas>
    </div>
</div>

<div class="grid">
    <div class="glass-card col-8">
        <div class="kpi-label">Fluxo de Caixa (Emissões)</div>
        <canvas id="chartTimeline" height="100"></canvas>
    </div>
    <div class="glass-card col-4">
        <div class="kpi-label">Mapa de Calor Geográfico</div>
        <div id="map"></div>
    </div>
</div>

<script>
    // Priority Chart (Horizontal Stacked Bar)
    const priorityData = <%- JSON.stringify(priorityChart || []) %>;
    if(priorityData.length > 0) {
        new Chart(document.getElementById('chartPriority').getContext('2d'), {
            type: 'bar',
            data: {
                labels: priorityData.map(c => {
                    const name = c.customer_name || '';
                    return name.length > 25 ? name.substring(0, 25) + '...' : name;
                }),
                datasets: [
                    { label: 'Crítico (>30d)', data: priorityData.map(c => parseFloat(c.critico)), backgroundColor: '#ff3b30' },
                    { label: 'Alerta (1-30d)', data: priorityData.map(c => parseFloat(c.alerta)), backgroundColor: '#ffcc00' },
                    { label: 'No Prazo', data: priorityData.map(c => parseFloat(c.noprazo)), backgroundColor: '#34c759' }
                ]
            },
            options: {
                indexAxis: 'y',
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { stacked: true, grid: { borderDash: [5, 5] }, ticks: {
                        callback: function(v) { return 'R$ ' + (v/1000).toFixed(0) + 'k'; }
                    }},
                    y: { stacked: true, grid: { display: false } }
                }
            }
        });
    }

    // Timeline Chart
    const timelineData = <%- JSON.stringify(timeline) %>;
    const ctx = document.getElementById('chartTimeline').getContext('2d');
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: Object.keys(timelineData),
            datasets: [{
                label: 'Faturamento',
                data: Object.values(timelineData),
                borderColor: '#007aff',
                backgroundColor: 'rgba(0, 122, 255, 0.1)',
                borderWidth: 2,
                fill: true,
                tension: 0.4,
                pointRadius: 0,
                pointHoverRadius: 6
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: { display: false } },
                y: { grid: { borderDash: [5, 5] } }
            }
        }
    });

    // Top Customers Chart
    const topCust = <%- JSON.stringify(topCustomers) %>;
    new Chart(document.getElementById('chartTopCustomers'), {
        type: 'doughnut',
        data: {
            labels: topCust.map(c => c.name.substring(0, 15)+'...'),
            datasets: [{
                data: topCust.map(c => c.total),
                backgroundColor: ['#38bdf8', '#818cf8', '#c084fc', '#f472b6', '#fb7185'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { position: 'right', labels: { boxWidth: 10 } } },
            cutout: '70%'
        }
    });

    // Map
    try {
        var map = L.map('map').setView([-15, -55], 4);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
            attribution: '&copy; OpenStreetMap &copy; CARTO',
            subdomains: 'abcd',
            maxZoom: 19
        }).addTo(map);

        const mapDataObj = <%- JSON.stringify(mapData) %>;
        const markers = [];
        
        Object.values(mapDataObj).forEach(city => {
            if(city.lat && city.lon) {
                L.circleMarker([city.lat, city.lon], {
                    radius: Math.min(Math.max(5, Math.sqrt(city.val)/100), 25),
                    fillColor: "#007aff",
                    color: "#fff",
                    weight: 1,
                    opacity: 1,
                    fillOpacity: 0.7
                }).addTo(map).bindPopup(`<b>${city.city}</b><br>R$ ${parseFloat(city.val).toLocaleString('pt-BR', {minimumFractionDigits: 2})}`);
                markers.push([city.lat, city.lon]);
            }
        });
        
        if(markers.length > 0) map.fitBounds(markers);
    } catch(e) { console.error("Map Error", e); }
</script>
